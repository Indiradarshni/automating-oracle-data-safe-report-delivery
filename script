oci_datasafe_reports.sh

#!/bin/bash

#############################################
# CONFIGURATION VARIABLES (populate the values)
#############################################

REGION="us-ashburn-1"  # OCI region

# TODO: Replace with your Security Assessment OCID
SECURITY_ASSESSMENT_OCID="ocid1.datasafesecurityassessment.oc1.iad.*******"

# TODO: Replace with your User Assessment OCID
USER_ASSESSMENT_OCID="ocid1.datasafeuserassessment.oc1.iad.*******"

# TODO: Replace with your Audit Report OCID
AUDIT_REPORT_ID="ocid1.datasafereport.oc1.iad.*******"

# TODO: Replace with your Object Storage bucket name
BUCKET_NAME="DataSafe-SecurityAssessment"

# TODO: Replace with your Notification Topic OCID
EXISTING_TOPIC_OCID="ocid1.onstopic.oc1.iad.******"

TMPFILE=~/datasafe-assessment.pdf
USER_TMPFILE=~/datasafe-user-assessment.pdf
AUDIT_PDF_FILE=~/datasafe-audit-report.pdf

# Optimized retry values
MAX_TRIES=15    # number of retries for downloads
SLEEP_SECS=5    # seconds to wait between retries

#############################################
# UTILITIES
#############################################

# Run command silently
run_silent() {
    "$@" 2>/dev/null
}

# 1 day ISO-8601 timestamp for PAR URL expiry
future_time() {
    date -u -Iseconds -d "+1 days"
}

# Generate a PAR URL
get_par_url() {
    local object_name="$1"
    local par_name="$2"
    local expires="$3"
    local namespace="$4"

    local par_uri
    par_uri=$(run_silent oci os preauth-request create \
        --bucket-name "$BUCKET_NAME" \
        --name "$par_name" \
        --object-name "$object_name" \
        --access-type ObjectRead \
        --time-expires "$expires" \
        --namespace "$namespace" \
        --region "$REGION" \
        --raw-output | jq -r '.data."access-uri"')

    echo "https://objectstorage.${REGION}.oraclecloud.com${par_uri}"
}

#############################################
# MAIN SCRIPT
#############################################

# Get Object Storage namespace
NAMESPACE=$(run_silent oci os ns get --query 'data' --raw-output --region "$REGION")

# --- SECURITY ASSESSMENT REPORT ---
echo "Generating Security Assessment..."
run_silent oci data-safe security-assessment generate-security-assessment-report \
    --security-assessment-id "$SECURITY_ASSESSMENT_OCID" --format PDF --region "$REGION"

i=0
while [ $i -lt $MAX_TRIES ]; do
    i=$((i+1))
    run_silent oci data-safe security-assessment download-security-assessment-report \
        --security-assessment-id "$SECURITY_ASSESSMENT_OCID" --format PDF --file "$TMPFILE" --region "$REGION" && break
    sleep $SLEEP_SECS
done
[ ! -f "$TMPFILE" ] && echo "ERROR: Security Assessment not downloaded!" && exit 1

SEC_OBJECT_NAME="datasafe-assessment-$(date +%F-%H%M%S).pdf"
run_silent oci os object put --bucket-name "$BUCKET_NAME" --name "$SEC_OBJECT_NAME" --file "$TMPFILE" --namespace "$NAMESPACE" --region "$REGION" --force

SEC_PAR_URL=$(get_par_url "$SEC_OBJECT_NAME" "${SEC_OBJECT_NAME}-par" "$(future_time)" "$NAMESPACE")
echo "Security Assessment PAR URL: $SEC_PAR_URL"

# --- USER ASSESSMENT REPORT ---
echo "Generating User Assessment..."
run_silent oci data-safe user-assessment generate-user-assessment-report \
    --user-assessment-id "$USER_ASSESSMENT_OCID" --format PDF --region "$REGION"

i=0
while [ $i -lt $MAX_TRIES ]; do
    i=$((i+1))
    run_silent oci data-safe user-assessment download-user-assessment-report \
        --user-assessment-id "$USER_ASSESSMENT_OCID" --format PDF --file "$USER_TMPFILE" --region "$REGION" && break
    sleep $SLEEP_SECS
done
[ ! -f "$USER_TMPFILE" ] && echo "ERROR: User Assessment not downloaded!" && exit 2

USER_OBJECT_NAME="datasafe-user-assessment-$(date +%F-%H%M%S).pdf"
run_silent oci os object put --bucket-name "$BUCKET_NAME" --name "$USER_OBJECT_NAME" --file "$USER_TMPFILE" --namespace "$NAMESPACE" --region "$REGION" --force

USER_PAR_URL=$(get_par_url "$USER_OBJECT_NAME" "${USER_OBJECT_NAME}-par" "$(future_time)" "$NAMESPACE")
echo "User Assessment PAR URL: $USER_PAR_URL"

# --- AUDIT REPORT ---
echo "Downloading Audit PDF..."
i=0
while [ $i -lt $MAX_TRIES ]; do
    i=$((i+1))
    run_silent oci data-safe report get-report-content --report-id "$AUDIT_REPORT_ID" --file "$AUDIT_PDF_FILE" --region "$REGION" && break
    sleep $SLEEP_SECS
done
[ ! -f "$AUDIT_PDF_FILE" ] && echo "ERROR: Audit PDF not downloaded!" && exit 3

AUDIT_OBJECT_NAME="datasafe-audit-pdf-$(date +%F-%H%M%S).pdf"
run_silent oci os object put --bucket-name "$BUCKET_NAME" --name "$AUDIT_OBJECT_NAME" --file "$AUDIT_PDF_FILE" --namespace "$NAMESPACE" --region "$REGION" --force

AUDIT_PAR_URL=$(get_par_url "$AUDIT_OBJECT_NAME" "${AUDIT_OBJECT_NAME}-par" "$(future_time)" "$NAMESPACE")
echo "Audit PDF PAR URL: $AUDIT_PAR_URL"

# --- SEND NOTIFICATION ---
MSG=$(cat <<EOF
Hello,

Your Data Safe reports are available (links expire in 1 day):

Security Assessment: $SEC_PAR_URL
User Assessment: $USER_PAR_URL
Audit Log PDF: $AUDIT_PAR_URL

Regards.
EOF
)

run_silent oci ons message publish --topic-id "$EXISTING_TOPIC_OCID" --body "$MSG"
echo "✅ Notification sent successfully!"
